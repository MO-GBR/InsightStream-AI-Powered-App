// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
  previewFeatures = ["postgresqlExtensions"] // Required for pgvector
}

datasource db {
  provider = "postgresql"
  extensions = [pg_graphql, pg_stat_statements, pgcrypto, supabase_vault, uuid_ossp(map: "uuid-ossp"), vector]
}

// ---------------------------------------------------------
// 1. USER & AUTH
// ---------------------------------------------------------

model User {
  id            String    @id @default(uuid()) // Match this to Supabase Auth UID
  email         String    @unique
  name          String?
  image         String?
  projects      Project[]
  plan          String    @default("basic")
  subscribed    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ---------------------------------------------------------
// 2. PROJECT (The "Brand" Container)
// ---------------------------------------------------------

model Project {
  id                String    @id @default(uuid())
  name              String
  keyword           String    // e.g., "Apple Vision Pro"
  competitorKeyword String?   // e.g., "Meta Quest 3"
  brandVoice        String    @default("Professional") // For AI Responses
  alertThreshold    Int       @default(20) // Percentage drop for Crisis Shield
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  mentions          Mention[]
  documents         Document[]
  briefings         Briefing[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
}

// ---------------------------------------------------------
// 3. MENTIONS & AI ANALYSIS
// ---------------------------------------------------------

model Mention {
  id              String    @id @default(uuid())
  content         String    @db.Text
  source          String    // "Twitter", "Reddit", "LinkedIn"
  author          String?
  isCompetitor    Boolean   @default(false)
  url             String?
  
  // Relations
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String
  analysis        Analysis? // 1-to-1: Every mention gets one AI verdict

  createdAt       DateTime  @default(now())

  @@index([projectId])
}

model Analysis {
  id             String   @id @default(uuid())
  mention        Mention  @relation(fields: [mentionId], references: [id], onDelete: Cascade)
  mentionId      String   @unique
  
  // Gemini Output Data
  sentimentScore Int      // 0 to 100
  label          String   // "Positive", "Negative", "Neutral", "Crisis"
  vibeColor      String   // Hex code generated by Gemini (e.g., "#EF4444")
  summary        String   @db.Text
  isCrisis       Boolean  @default(false)
  
  // The 3 AI drafts (Stored as JSON: { pro: string, witty: string, empathetic: string })
  suggestedReplies Json?    

  createdAt      DateTime @default(now())
}

// ---------------------------------------------------------
// 4. KNOWLEDGE VAULT (PDFs & RAG)
// ---------------------------------------------------------

model Document {
  id          String   @id @default(uuid())
  fileName    String
  fileUrl     String   // Supabase Storage URL
  
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  chunks      Chunk[]

  createdAt   DateTime @default(now())
}

model Chunk {
  id          String                 @id @default(uuid())
  content     String                 @db.Text
  
  // IMPORTANT: For 2026, we use pgvector for AI search
  // You will need to run `CREATE EXTENSION vector;` in your Supabase SQL editor
  embedding   Unsupported("vector")? 
  
  document    Document               @relation(fields: [docId], references: [id], onDelete: Cascade)
  docId       String

  @@index([docId])
}

// ---------------------------------------------------------
// 5. EXECUTIVE BRIEFINGS (Audio/Summary History)
// ---------------------------------------------------------

model Briefing {
  id          String   @id @default(uuid())
  summary     String   @db.Text
  audioUrl    String?  // If using ElevenLabs/TTS
  
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String

  createdAt   DateTime @default(now())
}